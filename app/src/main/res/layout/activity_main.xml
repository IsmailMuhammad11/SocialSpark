<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#F8F9FA">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Social Spark"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter a time of day and get a small social action to help you stay connected."
            android:textSize="16sp"
            android:textColor="#555555"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etTimeOfDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Example: Morning, Afternoon, Dinner"
            android:inputType="textCapWords"
            android:padding="14dp"
            android:backgroundTint="#6200EE" />

        <Button
            android:id="@+id/btnSuggest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Get Suggestion"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvResultLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Suggestion"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/tvSuggestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your social spark will appear here."
            android:textSize="18sp"
            android:textColor="#333333"
            android:padding="16dp"
            android:background="#EDEDED"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>